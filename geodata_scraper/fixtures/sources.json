      "igad_plus": ["DJI", "ERI", "ETH", "KEN", "SOM", "SSD", "SDN", "UGA", "BDI", "RWA", "TZA"],
      "eac": ["BDI", "COD", "KEN", "RWA", "SSD", "TZA", "UGA"]
