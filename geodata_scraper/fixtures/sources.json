    "layers": {
      "admin0": {
        "name": "Country Boundaries",
        "geometry_type": "MultiPolygon",
        "db_table_pattern": "{iso3_lower}_admin0",
        "parquet_file": "igad_admin0.parquet",
        "properties": {
          "GID_0":    {"type": "string", "max_length": 3,   "description": "ISO3 country code",       "example": "KEN", "index": true, "nullable": false},
          "COUNTRY":  {"type": "string", "max_length": 100, "description": "Country name",             "example": "Kenya", "nullable": false}
        }
      },
      "admin1": {
        "name": "Provinces / States / Counties",
        "geometry_type": "MultiPolygon",
        "db_table_pattern": "{iso3_lower}_admin1",
        "parquet_file": "igad_admin1.parquet",
        "properties": {
          "GID_0":     {"type": "string",  "max_length": 3,   "description": "ISO3 country code",              "example": "KEN",     "index": true,  "nullable": false},
          "GID_1":     {"type": "string",  "max_length": 20,  "description": "Admin1 GID (country.region)",    "example": "KEN.1_1", "index": true,  "nullable": false},
          "COUNTRY":   {"type": "string",  "max_length": 100, "description": "Country name",                    "example": "Kenya",   "nullable": false},
          "NAME_1":    {"type": "string",  "max_length": 200, "description": "Admin1 name",                     "example": "Nairobi", "index": true,  "nullable": false},
          "VARNAME_1": {"type": "string",  "max_length": 500, "description": "Alternate names (pipe-separated)","example": "Nairob",  "nullable": true},
          "NL_NAME_1": {"type": "string",  "max_length": 200, "description": "Name in national language",       "example": null,      "nullable": true},
          "TYPE_1":    {"type": "string",  "max_length": 100, "description": "Admin type in local language",     "example": "County",  "nullable": true},
          "ENGTYPE_1": {"type": "string",  "max_length": 100, "description": "Admin type in English",            "example": "County",  "nullable": true},
          "CC_1":      {"type": "string",  "max_length": 20,  "description": "Statistical code",                 "example": null,      "nullable": true},
          "HASC_1":    {"type": "string",  "max_length": 20,  "description": "HASC code",                        "example": "KE.NA",   "nullable": true},
          "ISO_1":     {"type": "string",  "max_length": 10,  "description": "ISO 3166-2 code",                  "example": "KE-30",   "nullable": true}
        }
      },
      "admin2": {
        "name": "Districts / Sub-counties",
        "geometry_type": "MultiPolygon",
        "db_table_pattern": "{iso3_lower}_admin2",
        "parquet_file": "igad_admin2.parquet",
