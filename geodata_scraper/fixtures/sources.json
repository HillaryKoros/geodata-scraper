[
  {
    "id": "gadm-v4.1",
    "name": "GADM v4.1",
    "description": "Global Administrative Areas — admin boundary polygons for all countries, levels 0-5",
    "source_type": "gadm",
    "protocol": "https",
    "version": "4.1",
    "base_url": "https://geodata.ucdavis.edu/gadm/gadm4.1/",
    "urls": {
      "gpkg": "https://geodata.ucdavis.edu/gadm/gadm4.1/gpkg/gadm41_{iso3}.gpkg",
