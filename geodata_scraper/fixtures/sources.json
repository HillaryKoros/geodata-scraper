    "countries": {
      "DJI": {"name": "Djibouti",    "admin_levels": 3, "approx_size_mb": 0.5},
      "ERI": {"name": "Eritrea",     "admin_levels": 3, "approx_size_mb": 2.0},
      "ETH": {"name": "Ethiopia",    "admin_levels": 4, "approx_size_mb": 18.0},
      "KEN": {"name": "Kenya",       "admin_levels": 4, "approx_size_mb": 46.0},
      "SOM": {"name": "Somalia",     "admin_levels": 3, "approx_size_mb": 5.0},
      "SSD": {"name": "South Sudan", "admin_levels": 3, "approx_size_mb": 0.8},
      "SDN": {"name": "Sudan",       "admin_levels": 3, "approx_size_mb": 3.8},
      "UGA": {"name": "Uganda",      "admin_levels": 4, "approx_size_mb": 20.0},
      "BDI": {"name": "Burundi",     "admin_levels": 4, "approx_size_mb": 11.0},
      "RWA": {"name": "Rwanda",      "admin_levels": 4, "approx_size_mb": 80.0},
      "TZA": {"name": "Tanzania",    "admin_levels": 4, "approx_size_mb": 30.0}
