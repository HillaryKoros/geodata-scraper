          "GID_0":     {"type": "string",  "max_length": 3,   "description": "ISO3 country code",              "example": "KEN",         "index": true,  "nullable": false},
          "GID_1":     {"type": "string",  "max_length": 20,  "description": "Admin1 GID",                      "example": "KEN.1_1",     "index": true,  "nullable": false},
          "GID_2":     {"type": "string",  "max_length": 30,  "description": "Admin2 GID",                      "example": "KEN.1.1_1",   "index": true,  "nullable": false},
          "COUNTRY":   {"type": "string",  "max_length": 100, "description": "Country name",                    "example": "Kenya",       "nullable": false},
          "NAME_1":    {"type": "string",  "max_length": 200, "description": "Admin1 name",                     "example": "Nairobi",     "index": true,  "nullable": false},
          "NAME_2":    {"type": "string",  "max_length": 200, "description": "Admin2 name",                     "example": "Westlands",   "index": true,  "nullable": false},
          "VARNAME_2": {"type": "string",  "max_length": 500, "description": "Alternate names",                  "example": null,          "nullable": true},
          "NL_NAME_2": {"type": "string",  "max_length": 200, "description": "Name in national language",       "example": null,          "nullable": true},
          "TYPE_2":    {"type": "string",  "max_length": 100, "description": "Admin type in local language",     "example": "Sub-county",  "nullable": true},
          "ENGTYPE_2": {"type": "string",  "max_length": 100, "description": "Admin type in English",            "example": "Sub-county",  "nullable": true},
          "CC_2":      {"type": "string",  "max_length": 20,  "description": "Statistical code",                 "example": null,          "nullable": true},
          "HASC_2":    {"type": "string",  "max_length": 20,  "description": "HASC code",                        "example": "KE.NA.WE",    "nullable": true}
        }
      },
      "admin3": {
        "name": "Wards / Communes",
        "geometry_type": "MultiPolygon",
        "db_table_pattern": "{iso3_lower}_admin3",
        "parquet_file": "igad_admin3.parquet",
        "properties": {
          "GID_0":     {"type": "string",  "max_length": 3,   "description": "ISO3 country code",    "index": true,  "nullable": false},
          "GID_1":     {"type": "string",  "max_length": 20,  "description": "Admin1 GID",            "index": true,  "nullable": false},
          "GID_2":     {"type": "string",  "max_length": 30,  "description": "Admin2 GID",            "index": true,  "nullable": false},
          "GID_3":     {"type": "string",  "max_length": 40,  "description": "Admin3 GID",            "index": true,  "nullable": false},
          "COUNTRY":   {"type": "string",  "max_length": 100, "description": "Country name",          "nullable": false},
          "NAME_1":    {"type": "string",  "max_length": 200, "description": "Admin1 name",           "nullable": false},
          "NAME_2":    {"type": "string",  "max_length": 200, "description": "Admin2 name",           "nullable": false},
          "NAME_3":    {"type": "string",  "max_length": 200, "description": "Admin3 name",           "index": true,  "nullable": false},
          "VARNAME_3": {"type": "string",  "max_length": 500, "description": "Alternate names",        "nullable": true},
          "NL_NAME_3": {"type": "string",  "max_length": 200, "description": "National language name", "nullable": true},
          "TYPE_3":    {"type": "string",  "max_length": 100, "description": "Admin type local",       "nullable": true},
          "ENGTYPE_3": {"type": "string",  "max_length": 100, "description": "Admin type English",     "nullable": true},
          "CC_3":      {"type": "string",  "max_length": 20,  "description": "Statistical code",       "nullable": true}
        }
      },
      "admin4": {
        "name": "Sub-wards / Villages",
        "geometry_type": "MultiPolygon",
        "db_table_pattern": "{iso3_lower}_admin4",
        "parquet_file": "igad_admin4.parquet",
        "properties": {
          "GID_0":     {"type": "string",  "max_length": 3,   "description": "ISO3 country code",    "index": true,  "nullable": false},
          "GID_1":     {"type": "string",  "max_length": 20,  "description": "Admin1 GID",            "index": true,  "nullable": false},
          "GID_2":     {"type": "string",  "max_length": 30,  "description": "Admin2 GID",            "index": true,  "nullable": false},
          "GID_3":     {"type": "string",  "max_length": 40,  "description": "Admin3 GID",            "index": true,  "nullable": false},
          "GID_4":     {"type": "string",  "max_length": 50,  "description": "Admin4 GID",            "index": true,  "nullable": false},
          "COUNTRY":   {"type": "string",  "max_length": 100, "description": "Country name",          "nullable": false},
          "NAME_1":    {"type": "string",  "max_length": 200, "description": "Admin1 name",           "nullable": false},
          "NAME_2":    {"type": "string",  "max_length": 200, "description": "Admin2 name",           "nullable": false},
          "NAME_3":    {"type": "string",  "max_length": 200, "description": "Admin3 name",           "nullable": false},
          "NAME_4":    {"type": "string",  "max_length": 200, "description": "Admin4 name",           "index": true,  "nullable": false},
          "VARNAME_4": {"type": "string",  "max_length": 500, "description": "Alternate names",        "nullable": true},
          "TYPE_4":    {"type": "string",  "max_length": 100, "description": "Admin type local",       "nullable": true},
          "ENGTYPE_4": {"type": "string",  "max_length": 100, "description": "Admin type English",     "nullable": true},
          "CC_4":      {"type": "string",  "max_length": 20,  "description": "Statistical code",       "nullable": true}
        }
      }
    },
    "storage": {
      "db_schema": "geodata_raw",
      "db_table_pattern": "{iso3_lower}_admin{level}",
      "parquet_path": "gadm/{region}/admin{level}/",
      "parquet_merged_pattern": "{region}_admin{level}.parquet",
      "object_storage_prefix": "s3://geodata/gadm/v4.1/"
    },
    "tags": ["boundaries", "administrative", "global", "vector"]
  },
